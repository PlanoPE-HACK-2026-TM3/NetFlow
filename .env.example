# NetFlow — root environment variables
# Copy to .env and fill values as needed.

# External APIs
RENTCAST_API_KEY=
FRED_API_KEY=

# LangSmith (optional)
LANGCHAIN_API_KEY=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
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=netflow-hackathon
LANGSMITH_EVAL_ENABLED=true


export ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Runtime mode
# true  = mock/demo-oriented behavior
# false = live mode (services still gracefully fall back if API keys are missing)
DEMO_MODE=false

# CORS origins for backend
ALLOWED_ORIGINS=http://localhost:3000,https://netflow.vercel.app
