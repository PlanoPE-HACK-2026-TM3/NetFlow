# =============================================================================
# NetFlow — environment configuration
# Copy this file to `.env` before running `docker compose up`.
#   cp .env.example .env
# =============================================================================

# --- Mode -------------------------------------------------------------------
# true  = demo data, rule-based scoring (no external API keys required)
# false = live RentCast + FRED data (requires keys below)
DEMO_MODE=true
DEBUG=false

# --- External data APIs (optional while DEMO_MODE=true) ---------------------
# Get a RentCast key: https://www.rentcast.io/api
# Get a FRED key:     https://fred.stlouisfed.org/docs/api/api_key.html
RENTCAST_API_KEY=
FRED_API_KEY=

# --- LangSmith tracing (optional) -------------------------------------------
# Leave blank to disable tracing.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=netflow-hackathon

# --- Ollama -----------------------------------------------------------------
# Do NOT change these unless you know what you're doing — docker-compose
# overrides OLLAMA_BASE_URL at runtime so the backend reaches the sibling
# container over the internal Docker network.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# --- Server -----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
