# NetFlow Backend — Environment Variables
# Copy this file to backend/.env and fill in your keys.
# start.sh does this automatically from the root .env.example

# ── External APIs ──────────────────────────────────────────────
RENTCAST_API_KEY=
FRED_API_KEY=

# ── LangSmith (optional) ───────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=netflow-hackathon

# ── Ollama ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Demo mode ──────────────────────────────────────────────────
# Auto-enabled when RENTCAST_API_KEY and FRED_API_KEY are both blank.
DEMO_MODE=false
