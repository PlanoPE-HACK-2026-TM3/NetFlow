backend/main.py.bkp
backend/main.py.bkpbkp
backend/main.py_0221
backend/main.py_0420
backend/agents/netflow_agent.py.bkp
backend/services/rentcast.py.bkp
backend/services/fred.py.bkp

# --- Environments & secrets ---
.env
.env.*
!.env.example
backend/.env
frontend/.env.local
*.key
*.pem
*.p12
secrets/

# --- Node (keep it out of the backend context entirely) ---
frontend/node_modules
frontend/.next
frontend/out
frontend/.vercel

# --- Logs & temp ---
*.log
/tmp
.langchain/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

